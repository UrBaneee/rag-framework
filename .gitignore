# =============================================================
# RAG Framework — .gitignore
# =============================================================

# ── Secrets / credentials ─────────────────────────────────
.env
*.pem
*.key
*_credentials.json
service_account*.json

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
wheels/
*.whl
pip-wheel-metadata/
.installed.cfg
MANIFEST

# ── Virtual environments ──────────────────────────────────
.venv/
venv/
env/
ENV/
.conda/

# ── Data / indexes / databases ────────────────────────────
data/
*.db
*.db-shm
*.db-wal
*.faiss
*.pkl
*.npy

# ── Jupyter ───────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── macOS ─────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── VSCode ────────────────────────────────────────────────
.vscode/
*.code-workspace

# ── pytest / coverage ─────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── mypy / ruff / linting ─────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Streamlit ─────────────────────────────────────────────
.streamlit/secrets.toml

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Personal / sensitive eval data ───────────────────────
tests/fixtures/resume_qrels.json

# ── Temp files ────────────────────────────────────────────
*.tmp
*.bak
*.swp
*~
