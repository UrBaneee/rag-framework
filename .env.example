# RAG Framework — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Voyage AI (reranker / embeddings) ─────────────────────
VOYAGE_API_KEY=pa-...

# ── Cohere (optional reranker, V2) ────────────────────────
COHERE_API_KEY=...

# ── Storage paths ─────────────────────────────────────────
# Directory where SQLite databases and FAISS index files are stored.
RAG_DATA_DIR=./data

# ── Embedding settings ────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── LLM settings ──────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ── Retrieval settings ────────────────────────────────────
RETRIEVAL_TOP_K=5
RERANK_ENABLED=true
RERANK_PROVIDER=voyage

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
